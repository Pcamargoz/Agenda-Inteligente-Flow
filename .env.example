# ============================================================
# Variáveis de ambiente — SMTP para envio de OS (exemplo)
# Copie este arquivo para .env.local para testes locais ou gerencie as variáveis
# no sistema de secrets da sua infraestrutura. Para orientações operacionais
# e recomendações de produção, consulte `docs/EMAIL_ENVIO.md`.
# ============================================================

# ---------- Servidor SMTP ----------
# Exemplos:
#   Gmail:      smtp.gmail.com         (porta 587, SECURE=false)
#   Outlook:    smtp.office365.com     (porta 587, SECURE=false)
#   Hostinger:  smtp.hostinger.com     (porta 465, SECURE=true)
#   Locaweb:    email-ssl.com.br       (porta 465, SECURE=true)
#   SendGrid:   smtp.sendgrid.net      (porta 587, SECURE=false, USER=apikey)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ---------- Credenciais ----------
# Para Gmail/Outlook: use uma SENHA DE APP (não a senha normal da conta).
#   Gmail: https://myaccount.google.com/apppasswords
#   Outlook: https://account.microsoft.com/security
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-aqui

# ---------- Remetente exibido ----------
# Geralmente igual ao SMTP_USER. Algumas contas permitem outro endereço autorizado.
SMTP_FROM=seu-email@gmail.com
SMTP_FROM_NAME=Faktory Flow Agenda

# ---------- Opcional ----------
# Cópia oculta automática (BCC) em todos os envios — útil para auditoria
# SMTP_BCC=auditoria@suaempresa.com
